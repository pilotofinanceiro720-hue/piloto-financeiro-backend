# ============================================================================
# PILOTO FINANCEIRO — Variáveis de Ambiente
# Configurações para Deploy no Railway (Supabase + Cloudflare R2)
# ============================================================================

# --- Core ---
NODE_ENV=production
JWT_SECRET=your_jwt_secret_here
PORT=3000

# --- Banco de Dados (Supabase / Postgres) ---
# O código atual usa dialeto MySQL, mas o usuário solicitou Supabase.
# Certifique-se de que o DATABASE_URL aponte para o Supabase (PostgreSQL).
# Nota: Se o código exigir MySQL, use uma instância MySQL no Railway ou ajuste o dialeto.
DATABASE_URL="postgresql://postgres:password@db.ocjgtbeswwprayuexwrf.supabase.co:5432/postgres"

# --- Google OAuth ---
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://api.pilotofinanceiro.com.br/api/oauth/callback
GOOGLE_REDIRECT_URI_MOBILE=pilotofinanceiro://oauth/callback

# --- Cloudflare R2 ---
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=your_bucket_name
R2_ENDPOINT=your_r2_endpoint_url

# --- Serviços Externos ---
ASAAS_API_KEY=your_asaas_key
ASAAS_SANDBOX=true
ASAAS_WEBHOOK_SECRET=your_webhook_secret
GEMINI_API_KEY=your_gemini_key

# --- App Config ---
API_BASE_URL=https://api.pilotofinanceiro.com.br
ADMIN_EMAIL=frederico.soares@pilotofinanceiro.com.br
SHORT_LINK_BASE=https://go.pilotofinanceiro.com.br
