{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install && npm run build"
  },
  "deploy": {
    "startCommand": "npm start",
    "healthcheckPath": "/api/health",
    "restartPolicy": {
      "maxRetries": 10
    },
    "numReplicas": 1
  },
  "environment": {
    "GOOGLE_REDIRECT_URI": "https://api.pilotofinanceiro.com.br/api/oauth/callback",
    "NODE_ENV": "production"
  }
}
